# Do not set PORT — deployment platforms (Vercel, Railway, etc.) inject it at runtime.
# Local development uses port 4000 by default (see backend/src/index.ts).

# Use a user with readWrite on the database, or a local Mongo with no auth (e.g. docker run -d -p 27017:27017 mongo:7)
MONGO_URI=mongodb://localhost:27017/hr-workflow

# CORS: optional extras — localhost + https://frontend-production-ca54.up.railway.app are always allowed in code.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=https://staging.example.com,https://www.example.com
